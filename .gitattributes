# Auto detect text files and perform LF normalization
* text=auto

# Explicit LF for IT MSP Platform file types
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.ps1   text eol=lf
*.txt   text eol=lf
*.json  text eol=lf

# Binary
*.zip   binary
*.png   binary
*.jpg   binary
*.pdf   binary
